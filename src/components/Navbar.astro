---
const pathname = Astro.url.pathname;

const links = [
  { href: '/',         label: '首頁' },
  { href: '/projects', label: '作品集' },
  { href: '/resume',   label: '履歷' },
  { href: '/contact',  label: '聯絡' },
];

function isActive(href: string) {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<nav class="navbar" id="navbar">
  <div class="navbar-inner">
    <a href="/" class="navbar-logo">Eason<span>.</span></a>
    <ul class="navbar-links">
      {links.map(({ href, label }) => (
        <li>
          <a href={href} class={`nav-link${isActive(href) ? ' active' : ''}`}>
            {label}
          </a>
        </li>
      ))}
    </ul>
  </div>
</nav>

<style>
  .navbar {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 1000;
    background: rgba(250, 250, 250, 0.85);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--color-border);
    transition: box-shadow var(--transition-base);
  }
  .navbar.scrolled {
    box-shadow: var(--shadow-md);
  }
  .navbar-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: var(--navbar-height);
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 24px;
  }
  .navbar-logo {
    font-family: var(--font-heading);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--color-primary);
  }
  .navbar-logo span { color: var(--color-accent); }
  .navbar-links {
    display: flex;
    gap: 4px;
    list-style: none;
  }
  .nav-link {
    display: block;
    padding: 8px 16px;
    border-radius: var(--radius-sm);
    font-size: 0.9rem;
    font-weight: 600;
    color: var(--color-secondary);
    transition: background var(--transition-fast), color var(--transition-fast);
  }
  .nav-link:hover {
    background: var(--color-muted);
    color: var(--color-primary);
  }
  .nav-link.active {
    color: var(--color-accent);
    background: var(--color-accent-light);
  }

  @media (max-width: 480px) {
    .nav-link { padding: 8px 10px; font-size: 0.8rem; }
    .navbar-logo { font-size: 1.2rem; }
  }
</style>

<script>
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    navbar?.classList.toggle('scrolled', window.scrollY > 20);
  }, { passive: true });
</script>
