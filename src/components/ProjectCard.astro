---
import type { Project } from '../data/projects';

interface Props {
  project: Project;
  delay?: number;
}

const { project, delay = 0 } = Astro.props;
const { name, description, tags, githubUrl, demoUrl, emoji, bgGradient, category, flowchartSvg } = project;
---

<article
  class="project-card fade-up"
  style={`transition-delay: ${delay}s`}
>
  <div
    class="project-thumbnail"
    style={bgGradient ? `background: ${bgGradient}` : ''}
  >
    {emoji && <span aria-hidden="true">{emoji}</span>}
  </div>
  <div class="project-body">
    <h3 class="project-name">{name}</h3>
    <p class="project-desc">{description}</p>
    <ul class="project-tags" aria-label="功能標籤">
      {tags.map((tag) => <li class="tag">{tag}</li>)}
    </ul>
    <div class="project-links">
      {demoUrl && (
        <a
          href={demoUrl}
          {...(demoUrl.startsWith('http') ? { target: '_blank', rel: 'noopener noreferrer' } : {})}
          class="project-link link-demo"
          aria-label={`${name} 線上 Demo`}
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13" aria-hidden="true">
            <circle cx="12" cy="12" r="10"/>
            <line x1="2" y1="12" x2="22" y2="12"/>
            <path d="M12 2a15.3 15.3 0 0 1 4 10 15.3 15.3 0 0 1-4 10 15.3 15.3 0 0 1-4-10 15.3 15.3 0 0 1 4-10z"/>
          </svg>
          Demo
        </a>
      )}
      {flowchartSvg ? (
        <button
          type="button"
          class="project-link link-detail js-open-modal"
          aria-label={`${name} 詳細介紹`}
          data-name={name}
          data-category={category}
          data-emoji={emoji ?? ''}
          data-description={description}
          data-tags={JSON.stringify(tags)}
          data-flowchart-svg={flowchartSvg}
          data-github={githubUrl ?? ''}
          data-demo={demoUrl ?? ''}
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13" aria-hidden="true">
            <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.44 5.44 0 0 0 14.5 2.5c-1.4 0-2.7.5-3.6 1.4"/>
          </svg>
          詳細介紹
        </button>
      ) : githubUrl ? (
        <a
          href={githubUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="project-link link-detail"
          aria-label={`${name} 詳細介紹`}
        >
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="13" height="13" aria-hidden="true">
            <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.44 5.44 0 0 0 14.5 2.5c-1.4 0-2.7.5-3.6 1.4"/>
          </svg>
          詳細介紹
        </a>
      ) : null}
    </div>
  </div>
</article>

<style>
  .project-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    overflow: hidden;
    display: flex;
    flex-direction: column;
    transition: transform var(--transition-base), box-shadow var(--transition-base), border-color var(--transition-base);
  }
  .project-card:hover {
    transform: translateY(-6px);
    box-shadow: var(--shadow-lg);
    border-color: #bfdbfe;
  }
  .project-thumbnail {
    height: 160px;
    background: linear-gradient(135deg, var(--color-muted), var(--color-accent-light));
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 2.5rem;
  }
  .project-thumbnail span {
    display: inline-block;
    transition: transform var(--transition-base);
  }
  .project-card:hover .project-thumbnail span {
    transform: scale(1.12) translateY(-3px);
  }
  .project-body {
    padding: 22px 22px 20px;
    flex: 1;
    display: flex;
    flex-direction: column;
  }
  .project-name {
    font-family: var(--font-heading);
    font-size: 1.05rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 8px;
    line-height: 1.3;
  }
  .project-desc {
    font-size: .875rem;
    color: var(--color-secondary);
    line-height: 1.7;
    margin-bottom: 16px;
    flex: 1;
  }
  .project-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 6px;
    margin-bottom: 18px;
    list-style: none;
  }
  .tag {
    font-size: .72rem;
    font-weight: 600;
    padding: 3px 10px;
    border-radius: var(--radius-full);
    background: var(--color-accent-light);
    color: var(--color-accent);
    border: 1px solid rgba(37,99,235,.2);
  }
  .project-links {
    display: flex;
    gap: 8px;
    flex-wrap: wrap;
  }
  .project-link {
    display: inline-flex;
    align-items: center;
    gap: 5px;
    font-size: .82rem;
    font-weight: 600;
    padding: 7px 16px;
    border-radius: var(--radius-sm);
    transition: all var(--transition-fast);
  }
  .link-demo {
    background: var(--color-primary);
    color: var(--color-on-primary);
    box-shadow: var(--shadow-sm);
  }
  .link-demo:hover {
    background: var(--color-accent);
    transform: translateY(-1px);
    box-shadow: var(--shadow-md);
  }
  .link-detail {
    background: transparent;
    color: var(--color-primary);
    border: 1.5px solid var(--color-border);
  }
  .link-detail:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    transform: translateY(-1px);
  }
</style>
