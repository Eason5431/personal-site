---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="聯絡 — Eason"
  description="開放求職、接案與各種有趣的對話。歡迎透過表單或社群平台聯繫 Eason。"
>
  <div class="container section">
    <h1 class="section-title fade-up">聯絡我</h1>
    <p class="section-subtitle fade-up">開放求職、接案與各種有趣的對話。</p>

    <div class="contact-layout">
      <!-- LEFT: Info + Social -->
      <div class="contact-info fade-up">
        <h2 class="contact-info-title">讓我們聊聊</h2>
        <p class="contact-info-desc">
          您有有趣的事情想聊嗎？無論是求職、接案或單純打聲招呼，都歡迎找我。
        </p>

        <!-- Detail cards: Email + Phone -->
        <ul class="detail-links">
          <li>
            <a href="mailto:easonyang5431work@gmail.com" class="detail-link">
              <div class="social-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                  <polyline points="22,6 12,13 2,6"/>
                </svg>
              </div>
              <div>
                <div class="social-name">Email</div>
                <div class="social-handle">easonyang5431work@gmail.com</div>
              </div>
            </a>
          </li>
          <li>
            <a href="tel:+88692783091" class="detail-link">
              <div class="social-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
                  <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07A19.5 19.5 0 0 1 4.69 12 19.79 19.79 0 0 1 1.61 3.4 2 2 0 0 1 3.6 1.22h3a2 2 0 0 1 2 1.72c.127.96.361 1.903.7 2.81a2 2 0 0 1-.45 2.11L7.91 8.76a16 16 0 0 0 6 6l.86-.86a2 2 0 0 1 2.11-.45c.907.339 1.85.573 2.81.7A2 2 0 0 1 21.5 16"/>
                </svg>
              </div>
              <div>
                <div class="social-name">Phone</div>
                <div class="social-handle">+886 92783091</div>
              </div>
            </a>
          </li>
        </ul>

        <!-- Icon-only row: LinkedIn / GitHub / Line@ / WhatsApp -->
        <div class="icon-row" aria-label="社群連結">
          <a href="https://www.linkedin.com/in/eason-yang-1ba135173" target="_blank" rel="noopener noreferrer"
             class="icon-btn" data-tip="LinkedIn" aria-label="LinkedIn">
            <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20" aria-hidden="true">
              <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 0 1-2.063-2.065 2.064 2.064 0 1 1 2.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
            </svg>
          </a>

          <a href="https://github.com/Eason5431" target="_blank" rel="noopener noreferrer"
             class="icon-btn" data-tip="GitHub" aria-label="GitHub">
            <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20" aria-hidden="true">
              <path d="M12 0C5.37 0 0 5.37 0 12c0 5.31 3.435 9.795 8.205 11.385.6.105.825-.255.825-.57 0-.285-.015-1.23-.015-2.235-3.015.555-3.795-.735-4.035-1.41-.135-.345-.72-1.41-1.23-1.695-.42-.225-1.02-.78-.015-.795.945-.015 1.62.87 1.845 1.23 1.08 1.815 2.805 1.305 3.495.99.105-.78.42-1.305.765-1.605-2.67-.3-5.46-1.335-5.46-5.925 0-1.305.465-2.385 1.23-3.225-.12-.3-.54-1.53.12-3.18 0 0 1.005-.315 3.3 1.23.96-.27 1.98-.405 3-.405s2.04.135 3 .405c2.295-1.56 3.3-1.23 3.3-1.23.66 1.65.24 2.88.12 3.18.765.84 1.23 1.905 1.23 3.225 0 4.605-2.805 5.625-5.475 5.925.435.375.81 1.095.81 2.22 0 1.605-.015 2.895-.015 3.3 0 .315.225.69.825.57A12.02 12.02 0 0 0 24 12c0-6.63-5.37-12-12-12z"/>
            </svg>
          </a>

          <button class="icon-btn" data-tip="Line@" aria-label="Line@" onclick="openQR('line')">
            <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20" aria-hidden="true">
              <path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63h2.386c.346 0 .627.285.627.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.63-.63.346 0 .628.285.628.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.281.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/>
            </svg>
          </button>

          <button class="icon-btn" data-tip="WhatsApp" aria-label="WhatsApp" onclick="openQR('whatsapp')">
            <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20" aria-hidden="true">
              <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
            </svg>
          </button>
        </div>
      </div>

      <!-- RIGHT: Form -->
      <form
        id="contact-form"
        action="https://formspree.io/f/xdapbdgb"
        method="POST"
        class="contact-form fade-up"
        style="transition-delay:0.1s"
        novalidate
      >
        <div class="form-group">
          <label class="form-label" for="name">姓名<span aria-hidden="true"> *</span></label>
          <input class="form-input" id="name" name="name" type="text" placeholder="你的姓名" required autocomplete="name" />
        </div>
        <div class="form-group">
          <label class="form-label" for="email">Email<span aria-hidden="true"> *</span></label>
          <input class="form-input" id="email" name="email" type="email" placeholder="your@email.com" required autocomplete="email" />
        </div>
        <div class="form-group">
          <label class="form-label" for="subject">主旨</label>
          <input class="form-input" id="subject" name="subject" type="text" placeholder="求職機會 / 接案合作 / 其他" autocomplete="off" />
        </div>
        <div class="form-group">
          <label class="form-label" for="message">訊息<span aria-hidden="true"> *</span></label>
          <textarea class="form-textarea" id="message" name="message" placeholder="告訴我你的想法或需求..." required></textarea>
        </div>
        <button type="submit" class="form-submit" id="submit-btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18" aria-hidden="true">
            <line x1="22" y1="2" x2="11" y2="13"/>
            <polygon points="22,2 15,22 11,13 2,9"/>
          </svg>
          送出訊息
        </button>
        <div id="form-success" class="form-success" hidden role="alert">
          ✓ 訊息已送出！我會在 24 小時內回覆你。
        </div>
        <div id="form-error" class="form-error" hidden role="alert">
          送出失敗，請稍後再試或直接寄信至 <a href="mailto:easonyang5431work@gmail.com">easonyang5431work@gmail.com</a>
        </div>
      </form>
    </div>
  </div>

  <!-- QR Modal: Line@ -->
  <div class="qr-overlay" id="qr-line" role="dialog" aria-modal="true" aria-label="Line@ QR Code">
    <div class="qr-modal">
      <button class="qr-close" onclick="closeQR('line')" aria-label="關閉">✕</button>
      <div class="qr-modal-title">Line@ QR Code</div>
      <img src="/qr/line-qr.jpg" alt="Line@ QR Code" class="qr-img" width="160" height="160" />
      <p class="qr-modal-desc">用手機掃描即可加入，<br>或搜尋 ID 直接聯繫。</p>
    </div>
  </div>

  <!-- QR Modal: WhatsApp -->
  <div class="qr-overlay" id="qr-whatsapp" role="dialog" aria-modal="true" aria-label="WhatsApp QR Code">
    <div class="qr-modal">
      <button class="qr-close" onclick="closeQR('whatsapp')" aria-label="關閉">✕</button>
      <div class="qr-modal-title">WhatsApp QR Code</div>
      <img src="/qr/whatsapp-qr.jpg" alt="WhatsApp QR Code" class="qr-img" width="160" height="160" />
      <p class="qr-modal-desc">用手機掃描即可開始對話。</p>
    </div>
  </div>
</BaseLayout>

<style>
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }
  .contact-info-title {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 12px;
  }
  .contact-info-desc {
    font-size: 0.95rem;
    color: var(--color-secondary);
    line-height: 1.75;
    margin-bottom: 24px;
  }

  /* Detail cards */
  .detail-links { display: flex; flex-direction: column; gap: 10px; margin-bottom: 16px; list-style: none; }
  .detail-link {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 18px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-primary);
    transition: all var(--transition-base);
  }
  .detail-link:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    transform: translateX(4px);
    box-shadow: var(--shadow-sm);
  }
  .social-icon {
    width: 36px; height: 36px;
    background: var(--color-muted);
    border-radius: var(--radius-sm);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    transition: background var(--transition-fast);
  }
  .detail-link:hover .social-icon { background: var(--color-accent-light); }
  .social-name  { font-size: 0.95rem; font-weight: 700; }
  .social-handle{ font-size: 0.8rem; color: var(--color-secondary); }
  .detail-link:hover .social-handle { color: var(--color-accent); }

  /* Icon-only row */
  .icon-row { display: flex; gap: 12px; flex-wrap: wrap; }
  .icon-btn {
    width: 48px; height: 48px;
    border-radius: var(--radius-md);
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    display: flex; align-items: center; justify-content: center;
    color: var(--color-primary);
    cursor: pointer;
    transition: all var(--transition-base);
    position: relative;
    text-decoration: none;
  }
  .icon-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    background: var(--color-accent-light);
    transform: translateY(-3px);
    box-shadow: var(--shadow-md);
  }
  .icon-btn::after {
    content: attr(data-tip);
    position: absolute;
    bottom: calc(100% + 8px);
    left: 50%;
    transform: translateX(-50%);
    background: var(--color-primary);
    color: #fff;
    font-size: 0.72rem;
    font-family: var(--font-body);
    padding: 4px 10px;
    border-radius: var(--radius-sm);
    white-space: nowrap;
    opacity: 0;
    pointer-events: none;
    transition: opacity var(--transition-fast);
  }
  .icon-btn:hover::after { opacity: 1; }

  /* QR Modal */
  .qr-overlay {
    display: none;
    position: fixed;
    inset: 0;
    background: rgba(0,0,0,0.45);
    z-index: 200;
    align-items: center;
    justify-content: center;
  }
  .qr-overlay.open { display: flex; }
  .qr-modal {
    background: var(--color-surface);
    border-radius: var(--radius-md);
    padding: 32px;
    width: 280px;
    box-shadow: var(--shadow-lg);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    position: relative;
  }
  .qr-modal-title {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 700;
    color: var(--color-primary);
  }
  .qr-img {
    width: 160px;
    height: 160px;
    border-radius: var(--radius-sm);
    object-fit: contain;
  }
.qr-modal-desc {
    font-size: 0.83rem;
    color: var(--color-secondary);
    text-align: center;
    line-height: 1.6;
    margin: 0;
  }
  .qr-close {
    position: absolute;
    top: 12px; right: 14px;
    font-size: 1rem;
    color: var(--color-secondary);
    cursor: pointer;
    background: none; border: none;
    font-family: inherit;
    transition: color var(--transition-fast);
  }
  .qr-close:hover { color: var(--color-destructive); }

  /* Form */
  .contact-form { display: flex; flex-direction: column; gap: 20px; }
  .form-group { display: flex; flex-direction: column; gap: 6px; }
  .form-label { font-size: 0.85rem; font-weight: 700; color: var(--color-primary); }
  .form-label span { color: var(--color-destructive); }
  .form-input, .form-textarea {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-foreground);
    background: var(--color-surface);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 12px 16px;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
    outline: none;
    width: 100%;
    min-height: 44px;
  }
  .form-input:focus, .form-textarea:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12);
  }
  .form-textarea { resize: vertical; min-height: 140px; line-height: 1.6; }
  .form-submit {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--color-accent);
    color: white;
    padding: 13px 32px;
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 700;
    border: none;
    cursor: pointer;
    transition: all var(--transition-base);
    min-height: 44px;
  }
  .form-submit:hover { background: #1d4ed8; transform: translateY(-2px); box-shadow: var(--shadow-md); }
  .form-submit:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
  .form-success {
    padding: 12px 16px;
    background: var(--color-success-bg);
    border: 1px solid var(--color-success-border);
    border-radius: var(--radius-md);
    font-size: 0.9rem;
    color: var(--color-success);
    font-weight: 600;
  }
  .form-error {
    padding: 12px 16px;
    background: #fee2e2;
    border: 1px solid #fca5a5;
    border-radius: var(--radius-md);
    font-size: 0.9rem;
    color: var(--color-destructive);
  }
  .form-error a { color: var(--color-accent); text-decoration: underline; }

  @media (max-width: 768px) {
    .contact-layout { grid-template-columns: 1fr; gap: 40px; }
  }
</style>

<script>
  // QR Modal
  (window as any).openQR = function(id: string) {
    document.getElementById('qr-' + id)?.classList.add('open');
  };
  (window as any).closeQR = function(id: string) {
    document.getElementById('qr-' + id)?.classList.remove('open');
  };
  document.querySelectorAll('.qr-overlay').forEach(overlay => {
    overlay.addEventListener('click', (e) => {
      if (e.target === overlay) overlay.classList.remove('open');
    });
  });
  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      document.querySelectorAll('.qr-overlay.open').forEach(el => el.classList.remove('open'));
    }
  });

  // Form submit
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;
  const successEl = document.getElementById('form-success') as HTMLElement;
  const errorEl = document.getElementById('form-error') as HTMLElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btn.innerHTML = `<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg> 送出中…`;

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (res.ok) {
        form.reset();
        btn.style.display = 'none';
        successEl.hidden = false;
      } else {
        throw new Error('送出失敗');
      }
    } catch {
      btn.disabled = false;
      btn.innerHTML = `<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22,2 15,22 11,13 2,9"/></svg> 送出訊息`;
      errorEl.hidden = false;
    }
  });
</script>
