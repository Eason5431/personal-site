---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="聯絡 — Eason"
  description="無論是求職機會、接案合作或單純打聲招呼，都歡迎聯繫。"
>
  <div class="container section">
    <h1 class="section-title fade-up">聯絡我</h1>
    <p class="section-subtitle fade-up">無論是求職機會、接案合作或單純打聲招呼，都歡迎聯繫</p>

    <div class="contact-layout">
      <!-- LEFT: Info + Social -->
      <div class="contact-info fade-up">
        <h2 class="contact-info-title">讓我們聊聊</h2>
        <p class="contact-info-desc">
          我目前開放全職求職機會與接案合作。如果你有有趣的專案或工作機會，
          請透過下方表單或社群平台與我聯繫，通常在 24 小時內回覆。
        </p>

        <ul class="social-links" aria-label="社群連結">
          <li>
            <a href="https://github.com/eason" target="_blank" rel="noopener noreferrer" class="social-link">
              <div class="social-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
                  <path d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.44 5.44 0 0 0 14.5 2.5c-1.4 0-2.7.5-3.6 1.4"/>
                </svg>
              </div>
              <div>
                <div class="social-name">GitHub</div>
                <div class="social-handle">github.com/eason</div>
              </div>
            </a>
          </li>
          <li>
            <a href="https://linkedin.com/in/eason" target="_blank" rel="noopener noreferrer" class="social-link">
              <div class="social-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
                  <path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"/>
                  <rect x="2" y="9" width="4" height="12"/>
                  <circle cx="4" cy="4" r="2"/>
                </svg>
              </div>
              <div>
                <div class="social-name">LinkedIn</div>
                <div class="social-handle">linkedin.com/in/eason</div>
              </div>
            </a>
          </li>
          <li>
            <a href="mailto:eason@example.com" class="social-link">
              <div class="social-icon" aria-hidden="true">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18">
                  <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
                  <polyline points="22,6 12,13 2,6"/>
                </svg>
              </div>
              <div>
                <div class="social-name">Email</div>
                <div class="social-handle">eason@example.com</div>
              </div>
            </a>
          </li>
        </ul>
      </div>

      <!-- RIGHT: Form -->
      <form
        id="contact-form"
        action="https://formspree.io/f/xdapbdgb"
        method="POST"
        class="contact-form fade-up"
        style="transition-delay:0.1s"
        novalidate
      >
        <div class="form-group">
          <label class="form-label" for="name">姓名<span aria-hidden="true"> *</span></label>
          <input class="form-input" id="name" name="name" type="text" placeholder="你的姓名" required autocomplete="name" />
        </div>
        <div class="form-group">
          <label class="form-label" for="email">Email<span aria-hidden="true"> *</span></label>
          <input class="form-input" id="email" name="email" type="email" placeholder="your@email.com" required autocomplete="email" />
        </div>
        <div class="form-group">
          <label class="form-label" for="subject">主旨</label>
          <input class="form-input" id="subject" name="subject" type="text" placeholder="求職機會 / 接案合作 / 其他" autocomplete="off" />
        </div>
        <div class="form-group">
          <label class="form-label" for="message">訊息<span aria-hidden="true"> *</span></label>
          <textarea class="form-textarea" id="message" name="message" placeholder="告訴我你的想法或需求..." required></textarea>
        </div>
        <button type="submit" class="form-submit" id="submit-btn">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="18" height="18" aria-hidden="true">
            <line x1="22" y1="2" x2="11" y2="13"/>
            <polygon points="22,2 15,22 11,13 2,9"/>
          </svg>
          送出訊息
        </button>
        <div id="form-success" class="form-success" hidden role="alert">
          ✓ 訊息已送出！我會在 24 小時內回覆你。
        </div>
        <div id="form-error" class="form-error" hidden role="alert">
          送出失敗，請稍後再試或直接寄信至 <a href="mailto:eason@example.com">eason@example.com</a>
        </div>
      </form>
    </div>
  </div>
</BaseLayout>

<style>
  .contact-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: start;
  }
  .contact-info-title {
    font-family: var(--font-heading);
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 12px;
  }
  .contact-info-desc {
    font-size: 0.95rem;
    color: var(--color-secondary);
    line-height: 1.75;
    margin-bottom: 32px;
  }
  .social-links { display: flex; flex-direction: column; gap: 12px; list-style: none; }
  .social-link {
    display: flex;
    align-items: center;
    gap: 14px;
    padding: 14px 18px;
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    color: var(--color-primary);
    transition: all var(--transition-base);
  }
  .social-link:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    transform: translateX(4px);
    box-shadow: var(--shadow-sm);
  }
  .social-icon {
    width: 36px; height: 36px;
    background: var(--color-muted);
    border-radius: var(--radius-sm);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    transition: background var(--transition-fast);
  }
  .social-link:hover .social-icon { background: var(--color-accent-light); }
  .social-name { font-size: 0.95rem; font-weight: 700; }
  .social-handle { font-size: 0.8rem; color: var(--color-secondary); }
  .social-link:hover .social-handle { color: var(--color-accent); }

  /* Form */
  .contact-form { display: flex; flex-direction: column; gap: 20px; }
  .form-group { display: flex; flex-direction: column; gap: 6px; }
  .form-label { font-size: 0.85rem; font-weight: 700; color: var(--color-primary); }
  .form-label span { color: var(--color-destructive); }
  .form-input, .form-textarea {
    font-family: var(--font-body);
    font-size: 0.95rem;
    color: var(--color-foreground);
    background: var(--color-surface);
    border: 1.5px solid var(--color-border);
    border-radius: var(--radius-md);
    padding: 12px 16px;
    transition: border-color var(--transition-fast), box-shadow var(--transition-fast);
    outline: none;
    width: 100%;
    min-height: 44px;
  }
  .form-input:focus, .form-textarea:focus {
    border-color: var(--color-accent);
    box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12);
  }
  .form-textarea { resize: vertical; min-height: 140px; line-height: 1.6; }
  .form-submit {
    align-self: flex-start;
    display: inline-flex;
    align-items: center;
    gap: 8px;
    background: var(--color-accent);
    color: white;
    padding: 13px 32px;
    border-radius: var(--radius-md);
    font-family: var(--font-body);
    font-size: 0.95rem;
    font-weight: 700;
    border: none;
    cursor: pointer;
    transition: all var(--transition-base);
    min-height: 44px;
  }
  .form-submit:hover { background: #1d4ed8; transform: translateY(-2px); box-shadow: var(--shadow-md); }
  .form-submit:disabled { opacity: 0.6; cursor: not-allowed; transform: none; }
  .form-success {
    padding: 12px 16px;
    background: var(--color-success-bg);
    border: 1px solid var(--color-success-border);
    border-radius: var(--radius-md);
    font-size: 0.9rem;
    color: var(--color-success);
    font-weight: 600;
  }
  .form-error {
    padding: 12px 16px;
    background: #fee2e2;
    border: 1px solid #fca5a5;
    border-radius: var(--radius-md);
    font-size: 0.9rem;
    color: var(--color-destructive);
  }
  .form-error a { color: var(--color-accent); text-decoration: underline; }

  @media (max-width: 768px) {
    .contact-layout { grid-template-columns: 1fr; gap: 40px; }
  }
</style>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement;
  const btn = document.getElementById('submit-btn') as HTMLButtonElement;
  const successEl = document.getElementById('form-success') as HTMLElement;
  const errorEl = document.getElementById('form-error') as HTMLElement;

  form?.addEventListener('submit', async (e) => {
    e.preventDefault();
    btn.disabled = true;
    btn.innerHTML = `<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><path d="M12 8v4l3 3"/></svg> 送出中…`;

    try {
      const res = await fetch(form.action, {
        method: 'POST',
        body: new FormData(form),
        headers: { Accept: 'application/json' },
      });

      if (res.ok) {
        form.reset();
        btn.style.display = 'none';
        successEl.hidden = false;
      } else {
        throw new Error('送出失敗');
      }
    } catch {
      btn.disabled = false;
      btn.innerHTML = `<svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2"><line x1="22" y1="2" x2="11" y2="13"/><polygon points="22,2 15,22 11,13 2,9"/></svg> 送出訊息`;
      errorEl.hidden = false;
    }
  });
</script>
