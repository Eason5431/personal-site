---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Eason — Full-Stack Developer & AI Builder"
  description="我打造 AI 工具、數據報表與網路產品。開放求職機會與接案合作。"
>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-text">
      <span class="hero-greeting fade-up">Hi, I'm Eason</span>
      <h1 class="hero-name fade-up" style="transition-delay:0.1s">
        Building<br /><span class="accent">Products</span><br />that matter.
      </h1>
      <p class="hero-role fade-up" style="transition-delay:0.2s">
        Full-Stack Developer &amp; AI Builder
      </p>
      <p class="hero-desc fade-up" style="transition-delay:0.25s">
        我打造 AI 工具、數據報表與網路產品。熱愛將複雜想法轉化成簡潔、可用的產品。
        開放求職機會與接案合作。
      </p>
      <div class="hero-ctas fade-up" style="transition-delay:0.3s">
        <a href="/resume" class="btn btn-primary">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14,2 14,8 20,8"/>
          </svg>
          查看履歷
        </a>
        <a href="/contact" class="btn btn-outline">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
          洽談合作
        </a>
      </div>
    </div>

    <div class="hero-avatar-wrap fade-up" style="transition-delay:0.15s">
      <div class="hero-avatar" aria-label="Eason 的頭像">E</div>
    </div>
  </section>

  <!-- TECH HIGHLIGHTS -->
  <section class="highlights-section" aria-label="技術亮點">
    <div class="container">
      <div class="highlights-grid">
        <div class="highlight-card fade-up">
          <div class="highlight-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22">
              <rect x="2" y="3" width="20" height="14" rx="2"/>
              <line x1="8" y1="21" x2="16" y2="21"/>
              <line x1="12" y1="17" x2="12" y2="21"/>
            </svg>
          </div>
          <div class="highlight-label">10+ Side Projects</div>
          <div class="highlight-desc">AI 工具、數據儀表板、Astro 網站、LINE Bot 等跨領域產品開發</div>
        </div>
        <div class="highlight-card fade-up" style="transition-delay:0.1s">
          <div class="highlight-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 8v4l3 3"/>
            </svg>
          </div>
          <div class="highlight-label">3 年開發經驗</div>
          <div class="highlight-desc">從設計、開發到部署一手包辦，熟悉 React、Node.js、Python 全端技術棧</div>
        </div>
        <div class="highlight-card fade-up" style="transition-delay:0.2s">
          <div class="highlight-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22">
              <path d="M12 20h9"/>
              <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
            </svg>
          </div>
          <div class="highlight-label">AI-Native 開發</div>
          <div class="highlight-desc">Claude API、LLM pipeline、Prompt Engineering，AI 驅動產品落地實戰</div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    min-height: calc(100vh - var(--navbar-height));
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 64px;
    max-width: 1100px;
    margin: 0 auto;
    padding: 80px 24px;
  }
  .hero-greeting {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent);
    background: var(--color-accent-light);
    padding: 4px 14px;
    border-radius: var(--radius-full);
    margin-bottom: 16px;
    letter-spacing: 0.04em;
  }
  .hero-name {
    font-family: var(--font-heading);
    font-size: clamp(2.4rem, 6vw, 4.2rem);
    font-weight: 700;
    line-height: 1.1;
    color: var(--color-primary);
    margin-bottom: 16px;
  }
  .hero-name .accent { color: var(--color-accent); }
  .hero-role {
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--color-secondary);
    margin-bottom: 20px;
  }
  .hero-desc {
    font-size: 0.97rem;
    color: var(--color-secondary);
    line-height: 1.75;
    max-width: 440px;
    margin-bottom: 36px;
  }
  .hero-ctas { display: flex; gap: 16px; flex-wrap: wrap; }
  .hero-avatar-wrap { display: flex; justify-content: center; }
  .hero-avatar {
    width: 300px;
    height: 300px;
    border-radius: 40% 60% 60% 40% / 40% 40% 60% 60%;
    background: linear-gradient(135deg, var(--color-accent-light), var(--color-muted));
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: var(--font-heading);
    font-size: 5rem;
    font-weight: 700;
    color: var(--color-accent);
    box-shadow: var(--shadow-lg);
    animation: morph 8s ease-in-out infinite;
  }
  @keyframes morph {
    0%,100% { border-radius: 40% 60% 60% 40% / 40% 40% 60% 60%; }
    25%      { border-radius: 60% 40% 40% 60% / 60% 60% 40% 40%; }
    50%      { border-radius: 50% 50% 60% 40% / 50% 40% 60% 50%; }
    75%      { border-radius: 40% 60% 50% 50% / 60% 50% 50% 40%; }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-avatar { animation: none; border-radius: 50%; }
  }
  .highlights-section { padding: 0 0 80px; }
  .highlights-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .highlight-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 28px;
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }
  .highlight-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); }
  .highlight-icon {
    width: 44px; height: 44px;
    background: var(--color-accent-light);
    border-radius: var(--radius-md);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 16px;
    color: var(--color-accent);
  }
  .highlight-label {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 6px;
  }
  .highlight-desc { font-size: 0.88rem; color: var(--color-secondary); line-height: 1.6; }

  @media (max-width: 768px) {
    .hero { grid-template-columns: 1fr; text-align: center; gap: 40px; padding: 48px 24px 64px; }
    .hero-avatar-wrap { order: -1; }
    .hero-avatar { width: 200px; height: 200px; font-size: 3.5rem; }
    .hero-desc { margin-left: auto; margin-right: auto; }
    .hero-ctas { justify-content: center; }
    .highlights-grid { grid-template-columns: 1fr; }
  }
</style>
