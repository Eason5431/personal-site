---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="Eason — Product Manager & AI Builder"
  description="具 5 年 FinTech 產品實戰背景，擅長用數據驅動增長決策、以 AI 工具加速產品交付。開放求職機會與接案合作。"
>
  <!-- HERO -->
  <section class="hero">
    <div class="hero-text">
      <span class="hero-greeting fade-up">Hi, I'm Eason</span>
      <h1 class="hero-name fade-up" style="transition-delay:0.1s">
        資深產品經理
        <span class="hero-name-sub accent">用戶增長 · AI 流程自動化</span>
      </h1>
      <p class="hero-role fade-up" style="transition-delay:0.2s">
        Product Manager &amp; AI Builder
      </p>
      <p class="hero-desc fade-up" style="transition-delay:0.25s">
        具 5 年 FinTech 產品實戰背景，擅長用數據驅動增長決策、以 AI 工具加速產品交付。開放求職機會與接案合作。
      </p>
      <div class="hero-ctas fade-up" style="transition-delay:0.3s">
        <a href="/resume" class="btn btn-primary">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
            <polyline points="14,2 14,8 20,8"/>
          </svg>
          查看履歷
        </a>
        <a href="/contact" class="btn btn-outline">
          <svg viewBox="0 0 24 24" width="18" height="18" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
            <path d="M21 15a2 2 0 0 1-2 2H7l-4 4V5a2 2 0 0 1 2-2h14a2 2 0 0 1 2 2z"/>
          </svg>
          洽談合作
        </a>
      </div>
    </div>

    <div class="hero-avatar-wrap fade-up" style="transition-delay:0.15s">
      <img
        src="/avatar.png"
        alt="Eason 的 Q 版頭像"
        class="hero-avatar-img"
        loading="eager"
      />
    </div>
  </section>

  <!-- TECH HIGHLIGHTS -->
  <section class="highlights-section" aria-label="技術亮點">
    <div class="container">
      <div class="highlights-grid">
        <div class="highlight-card fade-up">
          <div class="highlight-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22">
              <rect x="2" y="3" width="20" height="14" rx="2"/>
              <line x1="8" y1="21" x2="16" y2="21"/>
              <line x1="12" y1="17" x2="12" y2="21"/>
            </svg>
          </div>
          <div class="highlight-label">資深產業實務經驗</div>
          <div class="highlight-desc">具 5 年以上產品與專案管理經驗，深耕 FinTech 與加密貨幣交易所領域</div>
        </div>
        <div class="highlight-card fade-up" style="transition-delay:0.1s">
          <div class="highlight-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22">
              <circle cx="12" cy="12" r="10"/>
              <path d="M12 8v4l3 3"/>
            </svg>
          </div>
          <div class="highlight-label">AI 落地與流程自動化</div>
          <div class="highlight-desc">專精於運用 Claude Code 打造 AI 原生開發工作流，成功提升產品交付效率 40%</div>
        </div>
        <div class="highlight-card fade-up" style="transition-delay:0.2s">
          <div class="highlight-icon" aria-hidden="true">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="22" height="22">
              <path d="M12 20h9"/>
              <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z"/>
            </svg>
          </div>
          <div class="highlight-label">數據驅動與用戶增長</div>
          <div class="highlight-desc">曾主導多項增長專案，達成註冊轉化率提升 20% 與 MAU 增長 150% 之實績</div>
        </div>
      </div>
    </div>
  </section>
</BaseLayout>

<style>
  .hero {
    min-height: calc(100vh - var(--navbar-height));
    display: grid;
    grid-template-columns: 1fr 1fr;
    align-items: center;
    gap: 64px;
    max-width: 1100px;
    margin: 0 auto;
    padding: 80px 24px;
  }
  .hero-greeting {
    display: inline-block;
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--color-accent);
    background: var(--color-accent-light);
    padding: 4px 14px;
    border-radius: var(--radius-full);
    margin-bottom: 16px;
    letter-spacing: 0.04em;
  }
  .hero-name {
    font-family: var(--font-heading);
    font-size: clamp(2.4rem, 6vw, 4.2rem);
    font-weight: 700;
    line-height: 1.1;
    color: var(--color-primary);
    margin-bottom: 16px;
  }
  .hero-name .accent { color: var(--color-accent); }
  .hero-name-sub {
    display: block;
    font-size: clamp(1rem, 2.2vw, 1.4rem);
    font-weight: 500;
    color: var(--color-secondary);
    margin-top: 20px;
    letter-spacing: 0.01em;
  }
  .hero-role {
    font-size: 1.1rem;
    font-weight: 500;
    color: var(--color-secondary);
    margin-bottom: 20px;
  }
  .hero-desc {
    font-size: 0.97rem;
    color: var(--color-secondary);
    line-height: 1.75;
    max-width: 440px;
    margin-bottom: 36px;
  }
  .hero-ctas { display: flex; gap: 16px; flex-wrap: wrap; }
  .hero-avatar-wrap { display: flex; justify-content: center; align-items: center; }
  .hero-avatar-img {
    width: clamp(140px, 18vw, 220px);
    height: auto;
    object-fit: contain;
    transition: transform var(--transition-base);
  }
  .hero-avatar-img:hover {
    transform: translateY(-6px) scale(1.02);
  }
  .highlights-section { padding: 0 0 80px; }
  .highlights-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }
  .highlight-card {
    background: var(--color-surface);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-lg);
    padding: 28px;
    transition: transform var(--transition-base), box-shadow var(--transition-base);
  }
  .highlight-card:hover { transform: translateY(-4px); box-shadow: var(--shadow-md); }
  .highlight-icon {
    width: 44px; height: 44px;
    background: var(--color-accent-light);
    border-radius: var(--radius-md);
    display: flex; align-items: center; justify-content: center;
    margin-bottom: 16px;
    color: var(--color-accent);
  }
  .highlight-label {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 700;
    color: var(--color-primary);
    margin-bottom: 6px;
  }
  .highlight-desc { font-size: 0.88rem; color: var(--color-secondary); line-height: 1.6; }

  @media (max-width: 768px) {
    .hero { grid-template-columns: 1fr; text-align: center; gap: 40px; padding: 48px 24px 64px; }
    .hero-avatar-wrap { order: -1; }
.hero-desc { margin-left: auto; margin-right: auto; }
    .hero-ctas { justify-content: center; }
    .highlights-grid { grid-template-columns: 1fr; }
  }
</style>
